# Discord Bot Environment Variables
# Copy this file to bot/.env and fill in your values

# !! IMPORTANT: Never commit .env to git - it's in .gitignore !!
# This file contains sensitive information like your Discord bot token

# Your Discord Bot Token
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here_replace_this

# API Configuration (optional, leave as default for production)
# API_HOST=0.0.0.0
# API_PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
